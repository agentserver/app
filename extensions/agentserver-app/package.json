{
  "name": "agentserver-app",
  "displayName": "星池指挥官",
  "description": "让 VS Code 作为星池指挥官的简洁文件夹和会话界面",
  "publisher": "agentserver",
  "version": "0.1.6",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentserver/app.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --out agentserver-app-$npm_package_version.vsix --no-dependencies --skip-license",
    "test": "node ./out/test/runTest.js",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.9.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.3.3"
  },
  "contributes": {
    "configuration": {
      "title": "星池指挥官",
      "properties": {
        "agentserverApp.startup.openFolderIfEmpty": {
          "type": "boolean",
          "default": true,
          "description": "启动时如果还没有打开文件夹，就提示用户选择一个文件夹。"
        },
        "agentserverApp.terminal.respawnOnClose": {
          "type": "boolean",
          "default": true,
          "description": "关闭会话后自动创建新的会话。"
        },
        "agentserverApp.terminal.profileName": {
          "type": "string",
          "default": "codex",
          "description": "用于后台会话的内部配置名称。"
        },
        "agentserverApp.panel.hideViews": {
          "type": "array",
          "default": [
            "workbench.panel.markers.view",
            "workbench.panel.output",
            "workbench.panel.repl.view",
            "workbench.panel.comments",
            "~remote.forwardedPorts",
            "workbench.panel.testResults",
            "outline",
            "timeline"
          ],
          "description": "高级设置：需要隐藏的 VS Code 内部视图。"
        }
      }
    },
    "commands": [
      {
        "command": "agentserverApp.doctor",
        "title": "星池指挥官: 诊断工具"
      },
      {
        "command": "agentserverApp.reopenCodexTerminal",
        "title": "星池指挥官: 创建新的会话"
      },
      {
        "command": "agentserverApp.openWithSystem",
        "title": "用系统应用打开"
      },
      {
        "command": "agentserverApp.showAdvancedInterface",
        "title": "星池指挥官: 显示高级界面"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "agentserverApp.showAdvancedInterface",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "agentserverApp.openWithSystem",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@90"
        }
      ]
    }
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "9.0.0"
  },
  "allowScripts": {
    "@vscode/vsce-sign": false,
    "keytar": false
  }
}
